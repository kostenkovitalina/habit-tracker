{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:schema": "cross-env NODE_OPTIONS=--no-deprecation payload generate:db-schema",
    "migrate:dev": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "migrate:dep": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix",
    "prettier": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,scss}\"",
    "type-check": "tsc --noEmit",
    "format": "yarn type-check && yarn lint && yarn prettier",
    "test": "yarn test:int && yarn test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" yarn exec playwright test",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "dev": "yarn generate:types && yarn generate:importmap && yarn migrate:dep && nodemon",
    "build": "yarn migrate:dep && next build && tsup",
    "start": "cross-env NODE_ENV=production node dist/server.js"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@payloadcms/db-postgres": "3.66.0",
    "@payloadcms/next": "3.66.0",
    "@payloadcms/plugin-seo": "^3.66.0",
    "@payloadcms/richtext-lexical": "3.66.0",
    "@payloadcms/storage-s3": "^3.66.0",
    "@payloadcms/ui": "3.66.0",
    "@t3-oss/env-core": "^0.13.8",
    "better-auth": "^1.4.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "fastify-cacheman": "^5.0.0",
    "fastify-graceful-shutdown": "^5.0.0",
    "fastify-type-provider-zod": "^6.1.0",
    "graphql": "^16.12.0",
    "next": "15.5.12",
    "payload": "3.66.0",
    "payload-lexical-typography": "^0.5.2",
    "postgres": "^3.4.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "sharp": "0.34.5",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "1.57.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@vitejs/plugin-react": "5.1.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.0.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jsdom": "27.2.0",
    "nodemon": "^3.1.11",
    "playwright": "1.57.0",
    "playwright-core": "1.57.0",
    "prettier": "^3.7.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "4.0.14"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@1.22.22",
  "volta": {
    "node": "22.22.0",
    "yarn": "1.22.22"
  }
}
